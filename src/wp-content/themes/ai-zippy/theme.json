{
	"$schema": "https://schemas.wp.org/trunk/theme.json",
	"version": 3,
	"settings": {
		"appearanceTools": true,
		"color": {
			"palette": [
				{
					"slug": "primary",
					"color": "#1A0A0D",
					"name": "Primary (Text)"
				},
				{
					"slug": "crimson",
					"color": "#8B1C3F",
					"name": "Crimson"
				},
				{
					"slug": "crimson-mid",
					"color": "#A3234B",
					"name": "Crimson Mid"
				},
				{
					"slug": "gold",
					"color": "#B8964A",
					"name": "Gold"
				},
				{
					"slug": "bg-light",
					"color": "#F8F5F0",
					"name": "BG Light"
				},
				{
					"slug": "bg-cream",
					"color": "#F0EBE3",
					"name": "BG Cream"
				},
				{
					"slug": "white",
					"color": "#ffffff",
					"name": "White"
				},
				{
					"slug": "black",
					"color": "#000000",
					"name": "Black"
				},
				{
					"slug": "border",
					"color": "rgba(184,150,74,0.22)",
					"name": "Border (Gold)"
				},
				{
					"slug": "border-light",
					"color": "rgba(26,10,13,0.08)",
					"name": "Border Light"
				},
				{
					"slug": "muted",
					"color": "rgba(26,10,13,0.55)",
					"name": "Muted"
				}
			]
		},
		"custom": {
			"breakpoint": {
				"sm": "480px",
				"md": "768px",
				"lg": "1024px",
				"xl": "1200px",
				"xxl": "1400px"
			}
		},
		"typography": {
			"fontFamilies": [
				{
					"fontFamily": "-apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, Cantarell, 'Helvetica Neue', sans-serif",
					"slug": "system",
					"name": "System"
				},
				{
					"fontFamily": "'Cormorant Garamond', serif",
					"slug": "serif",
					"name": "Serif (Cormorant Garamond)"
				},
				{
					"fontFamily": "'Montserrat', sans-serif",
					"slug": "sans",
					"name": "Sans (Montserrat)"
				}
			],
			"fontSizes": [
				{
					"slug": "small",
					"size": "0.875rem",
					"name": "Small"
				},
				{
					"slug": "medium",
					"size": "1rem",
					"name": "Medium"
				},
				{
					"slug": "large",
					"size": "1.5rem",
					"name": "Large"
				},
				{
					"slug": "x-large",
					"size": "2.25rem",
					"name": "Extra Large"
				}
			]
		},
		"layout": {
			"contentSize": "1200px",
			"wideSize": "1400px"
		},
		"spacing": {
			"units": ["px", "em", "rem", "%", "vw", "vh"]
		}
	},
	"styles": {
		"color": {
			"background": "var(--wp--preset--color--white)",
			"text": "var(--wp--preset--color--primary)"
		},
		"typography": {
			"fontFamily": "var(--wp--preset--font-family--system)",
			"fontSize": "var(--wp--preset--font-size--medium)",
			"lineHeight": "1.6"
		},
		"spacing": {
			"blockGap": "0"
		}
	},
	"templateParts": [
		{
			"name": "header",
			"title": "Header",
			"area": "header"
		},
		{
			"name": "footer",
			"title": "Footer",
			"area": "footer"
		}
	],
	"customTemplates": [
		{
			"name": "blank",
			"title": "Blank",
			"postTypes": ["page", "post"]
		},
		{
			"name": "page-about",
			"title": "About",
			"postTypes": ["page"]
		},
		{
			"name": "page-contact",
			"title": "Contact",
			"postTypes": ["page"]
		},
		{
			"name": "page-cart",
			"title": "Cart",
			"postTypes": ["page"]
		},
		{
			"name": "page-checkout",
			"title": "Checkout",
			"postTypes": ["page"]
		}
	]
}
