{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "ai-zippy/az-product-grid",
	"version": "1.0.0",
	"title": "AZ: Product Grid",
	"category": "ai-zippy",
	"icon": "grid-view",
	"description": "Product grid for best sellers or new arrivals.",
	"supports": {
		"html": false,
		"anchor": true,
		"align": ["wide", "full"]
	},
	"attributes": {
		"align": {
			"type": "string",
			"default": "full"
		},
		"eyebrow": { "type": "string", "default": "Shop Our Finest" },
		"title": { "type": "string", "default": "Best Sellers" },
		"viewAllText": { "type": "string", "default": "View All →" },
		"viewAllUrl": { "type": "string", "default": "#" },
		"products": {
			"type": "array",
			"default": []
		},
		"limit": {
			"type": "number",
			"default": 4
		},
		"category": {
			"type": "string",
			"default": ""
		},
		"orderby": {
			"type": "string",
			"default": "date"
		},
		"order": {
			"type": "string",
			"default": "DESC"
		}
	},
	"textdomain": "ai-zippy",
	"editorScript": "file:./index.js",
	"style": "file:./style-index.css",
	"render": "file:./render.php"
}
