		"title": { "type": "string", "default": "Find Us" },
		"subtitle": { "type": "string", "default": "Two boutiques in the heart of Singapore's CBD" }
	},
	"textdomain": "ai-zippy",
	"editorScript": "file:./index.js",
	"render": "file:./render.php"
}
