{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "ai-zippy/az-contact-hero",
	"version": "1.0.0",
	"title": "AZ: Contact Hero",
	"category": "ai-zippy",
	"icon": "cover-image",
	"description": "Hero section for Contact page.",
	"supports": {
		"html": false,
		"anchor": true,
		"align": ["full"]
	},
	"attributes": {
		"align": { "type": "string", "default": "full" },
