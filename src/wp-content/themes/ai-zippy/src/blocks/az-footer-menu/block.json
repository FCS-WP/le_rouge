{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "ai-zippy/az-footer-menu",
	"version": "1.0.0",
	"title": "AZ: Footer Menu",
	"category": "ai-zippy",
	"icon": "menu",
	"description": "Footer column with a heading and a list of links.",
	"attributes": {
		"title": { "type": "string", "default": "Shop" },
		"links": {
			"type": "array",
			"default": [
				{ "label": "Red Wine", "url": "/product-category/red-wine" },
				{ "label": "White Wine", "url": "/product-category/white-wine" },
				{ "label": "Spirits", "url": "/product-category/spirits" },
				{ "label": "Chocolates", "url": "/product-category/chocolates" }
			]
		}
	},
	"textdomain": "ai-zippy",
	"editorScript": "file:./index.js",
	"style": "file:./style-index.css",
	"render": "file:./render.php"
}
