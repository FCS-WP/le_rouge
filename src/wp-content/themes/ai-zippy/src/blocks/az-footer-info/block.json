{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "ai-zippy/az-footer-info",
	"version": "1.0.0",
	"title": "AZ: Footer Info",
	"category": "ai-zippy",
	"icon": "info-outline",
	"description": "Column with logo, description and outlet contact info.",
	"supports": {
		"html": false,
		"anchor": true
	},
	"attributes": {
		"logoId": { "type": "number" },
		"logoUrl": { "type": "string" },
		"description": {
			"type": "string",
			"default": "Singapore's premier boutique for fine wine and premium spirits. Expertly curated for the discerning palate."
		},
		"outlet1Title": { "type": "string", "default": "Raffles Place" },
		"outlet1Address": { "type": "string", "default": "16 Collyer Quay, #01-08, S049318" },
		"outlet1Hours": { "type": "string", "default": "Weekdays: 10.30am – 8pm\nClosed Sat, Sun & PH" },
		"outlet2Title": { "type": "string", "default": "Marina Bay Link Mall" },
		"outlet2Address": { "type": "string", "default": "8A Marina Boulevard, #B2-34, S018984" },
		"outlet2Hours": { "type": "string", "default": "Weekdays: 10.30am – 8pm\nSaturdays: 12pm – 4pm\nSun & PH closed" }
	},
	"textdomain": "ai-zippy",
	"editorScript": "file:./index.js",
	"style": "file:./style-index.css",
	"render": "file:./render.php"
}
