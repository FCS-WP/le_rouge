{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "ai-zippy/az-best-sellers",
	"version": "1.0.0",
	"title": "AZ: Best Sellers",
	"category": "ai-zippy",
	"icon": "awards",
	"description": "Display selected best seller products with a category fallback.",
	"supports": {
		"html": false,
		"anchor": true,
		"align": ["wide", "full"]
	},
	"attributes": {
		"align": {
			"type": "string",
			"default": "full"
		},
		"eyebrow": { "type": "string", "default": "Shop Our Finest" },
		"title": { "type": "string", "default": "Best Sellers" },
		"viewAllText": { "type": "string", "default": "View All →" },
		"viewAllUrl": { "type": "string", "default": "#" },
		"selectedProductIds": {
			"type": "array",
			"default": [],
			"items": {
				"type": "number"
			}
		},
		"limit": { "type": "number", "default": 4 },
		"desktopColumns": { "type": "number", "default": 4 },
		"desktopRows": { "type": "number", "default": 1 },
		"category": { "type": "string", "default": "best-sellers" },
		"orderby": {
			"type": "string",
			"default": "date"
		},
		"order": {
			"type": "string",
			"default": "DESC"
		}
	},
	"textdomain": "ai-zippy",
	"editorScript": "file:./index.js",
	"style": "file:./style-index.css",
	"render": "file:./render.php"
}
